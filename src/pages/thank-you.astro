---
import Base from '../layouts/Base.astro';
---

<Base title="You're In" description="Check your email for the Operator's Toolkit PDF.">

  <section style="padding:5rem 2rem 3rem; text-align:center;">
    <div style="max-width:640px; margin:0 auto;">
      <div style="width:64px; height:64px; background:rgba(0,137,123,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; font-size:1.75rem;">
        ✓
      </div>
      <h1 style="font-size:clamp(1.75rem, 3vw, 2.5rem); color:var(--navy); margin-bottom:0.75rem;">You're In. Check Your Email.</h1>
      <p style="font-size:1.1rem; color:var(--gray-600); line-height:1.7; max-width:520px; margin:0 auto 1.5rem;">
        A confirmation email is on its way from <strong style="color:var(--navy);">info@mail.operatorstack.tech</strong>.
        Click confirm and the Operator's Toolkit PDF lands in your inbox.
      </p>
      <p style="font-size:0.9rem; color:var(--gray-400); background:var(--gray-50); border:1px solid var(--gray-200); border-radius:8px; padding:0.75rem 1.25rem; display:inline-block;">
        Check your spam folder if you don't see it in 2 minutes.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:3rem;">
    <div class="container" style="max-width:860px;">
      <div style="text-align:center; margin-bottom:2.5rem;">
        <p class="section-label">While You Wait</p>
        <h2 style="font-size:1.5rem; color:var(--navy); font-weight:800;">Start Here</h2>
      </div>

      <div class="card-grid">
        <a href="/reviews/gohighlevel" class="post-card">
          <div class="post-card-body">
            <span class="post-card-tag">CRM Review</span>
            <h3>GoHighLevel Review 2026</h3>
            <p>The all-in-one CRM for multi-location operators. thousands of venues tested, honest pros and cons.</p>
            <div class="post-card-meta">
              <span>12 min read</span>
            </div>
          </div>
        </a>

        <a href="/guides/operator-tech-stack" class="post-card">
          <div class="post-card-body">
            <span class="post-card-tag">Stack Guide</span>
            <h3>The Operator's Tech Stack</h3>
            <p>Every tool I pay for monthly with exact costs and what each one replaced.</p>
            <div class="post-card-meta">
              <span>9 min read</span>
            </div>
          </div>
        </a>

        <a href="/guides/crm-for-operators" class="post-card">
          <div class="post-card-body">
            <span class="post-card-tag">CRM Guide</span>
            <h3>Best CRM for Multi-Location Businesses</h3>
            <p>Five CRMs tested across thousands of venues. Most fail at scale. Here's what holds up.</p>
            <div class="post-card-meta">
              <span>13 min read</span>
            </div>
          </div>
        </a>
      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/reviews" class="btn btn-outline">Browse All Reviews →</a>
      </div>
    </div>
  </section>

</Base>
