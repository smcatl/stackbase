---
<Base
  title="Operator Guides -- OperatorStack"
  description="How-to guides and software roundups for multi-location business operators. CRM, email, automation, WiFi, and more."
>
  <div style="background:var(--gray-50); border-bottom:1px solid var(--gray-200); padding:4rem 1.5rem 3rem;">
    <div class="container">
      <p class="section-label">Guides</p>
      <h1 style="margin-bottom:.75rem;">Operator Guides</h1>
      <p style="font-size:1.05rem; color:var(--gray-600); max-width:560px;">
        How-to guides and roundups written from direct deployment experience. No theory -- just what works in the field.
      </p>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="card-grid">
        {guides.map(guide => (
          <a href={guide.href} class="post-card">
            <div class="post-card-body">
              <span class="post-card-tag">{guide.tag}</span>
              <h3>{guide.title}</h3>
              <p>{guide.excerpt}</p>
              <div class="post-card-meta">
                <span>{guide.date}</span>
                <span>·</span>
                <span>{guide.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Base>
