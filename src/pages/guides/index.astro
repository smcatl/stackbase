---
import Base from '../../layouts/Base.astro';

const guides = [
  {
    tag: 'Stack',
    title: "The Operator's Tech Stack: 8 Tools That Run My Business",
    excerpt: 'Every tool I pay for monthly -- CRM, email, automation, networking, billing -- with exact costs and what each replaced.',
    href: '/guides/operator-tech-stack',
    date: 'Mar 13, 2026',
    readTime: '9 min',
  },
  {
    tag: 'Automation',
    title: "How to Automate Client Onboarding: The Operator's 8-Step System",
    excerpt: 'We onboard new venue partners across thousands of locations without touching anything manually. Here is the exact system.',
    href: '/guides/automate-onboarding',
    date: 'Mar 14, 2026',
    readTime: '12 min',
  },
  {
    tag: 'CRM',
    title: 'Best CRM for Multi-Location Businesses in 2026',
    excerpt: 'Tested across thousands of venues. Most CRMs fail at scale. Here are the five that actually hold up when you are managing multiple locations.',
    href: '/guides/crm-for-operators',
    date: 'Mar 14, 2026',
    readTime: '13 min',
  },
  {
    tag: 'Email',
    title: 'Best Email Marketing Software for Small Business in 2026',
    excerpt: 'Tested six platforms. Here is which email tool actually works for operators building lists and running automations.',
    href: '/guides/best-email-marketing',
    date: 'Mar 14, 2026',
    readTime: '11 min',
  },
  {
    tag: 'Restaurant',
    title: 'Best Software for Restaurant Chains and Multi-Location Food Service (2026)',
    excerpt: 'POS, scheduling, payroll, CRM, email, and WiFi -- the complete stack for multi-location restaurant operators.',
    href: '/guides/best-restaurant-software',
    date: 'Mar 14, 2026',
    readTime: '10 min',
  },
  {
    tag: 'Franchise',
    title: 'Best Software for Franchise Operations in 2026',
    excerpt: 'CRM, training, project management, contracts, automation, and payroll for franchise operators scaling to thousands of units.',
    href: '/guides/best-franchise-software',
    date: 'Mar 14, 2026',
    readTime: '10 min',
  },
  {
    tag: 'Salon',
    title: 'Best Software for Salon and Spa Chains in 2026',
    excerpt: 'Booking, CRM, email, payroll, and WiFi management for multi-location salon and spa operators.',
    href: '/guides/best-salon-software',
    date: 'Mar 14, 2026',
    readTime: '10 min',
  },
  {
    tag: 'Retail',
    title: 'Best Software for Multi-Location Retail in 2026',
    excerpt: 'POS, inventory, CRM, email, and payroll for retail chains scaling across multiple locations.',
    href: '/guides/best-retail-software',
    date: 'Mar 14, 2026',
    readTime: '10 min',
  },
  {
    tag: 'WiFi',
    title: 'Best WiFi Management Software for Multi-Location Venues (2026)',
    excerpt: 'How to manage WiFi across thousands of venues -- access point selection, cloud management, captive portals, and network infrastructure.',
    href: '/guides/best-wifi-management',
    date: 'Mar 18, 2026',
    readTime: '11 min',
  },
  {
    tag: 'CRM',
    title: 'GoHighLevel Pricing 2026: What You Actually Pay at Every Tier',
    excerpt: 'Starter $97, Agency Unlimited $297, SaaS $497 -- what each tier includes, hidden costs, and which one operators actually need.',
    href: '/guides/gohighlevel-pricing',
    date: 'Mar 19, 2026',
    readTime: '8 min',
  },
  {
    tag: 'HR',
    title: 'Best Payroll Software for Multi-Location Small Business in 2026',
    excerpt: 'Gusto, QuickBooks, ADP, and Paychex compared for multi-location operators. Multi-state compliance, tip tracking, and pricing at scale.',
    href: '/guides/best-payroll-software',
    date: 'Mar 25, 2026',
    readTime: '11 min',
  },
  {
    tag: 'Operations',
    title: 'Best Employee Scheduling Software for Multi-Location Businesses (2026)',
    excerpt: 'Homebase, When I Work, Deputy, and 7shifts compared. Features, pricing, and which works best for multi-location operators.',
    href: '/guides/best-scheduling-software',
    date: 'Mar 26, 2026',
    readTime: '10 min',
  },
  {
    tag: 'Restaurant',
    title: 'Best POS Systems for Multi-Location Restaurants in 2026',
    excerpt: 'Toast, Square, Lightspeed, and Clover compared. Which POS scales best for multi-unit restaurant operations.',
    href: '/guides/best-pos-restaurants',
    date: 'Mar 31, 2026',
    readTime: '12 min',
  },
  {
    tag: 'CRM',
    title: 'GoHighLevel Snapshots: The Feature That Makes Multi-Location Management Possible',
    excerpt: 'Deep dive into Snapshots -- what they capture, how to build one, and a real-world deployment workflow.',
    href: '/guides/gohighlevel-snapshots',
    date: 'Apr 1, 2026',
    readTime: '8 min',
  },
  {
    tag: 'Automation',
    title: 'How to Build a Partner Onboarding System That Runs Itself',
    excerpt: 'The exact 8-step automated onboarding system running across thousands of venues using GHL, PandaDoc, Tally, and Zapier.',
    href: '/guides/build-partner-onboarding-system',
    date: 'Apr 2, 2026',
    readTime: '12 min',
  },
