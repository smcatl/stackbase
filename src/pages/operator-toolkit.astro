---
import Base from '../layouts/Base.astro';
---

<Base title="The Operator's Software Toolkit -- Free Download" description="12 tools reviewed and stack-ranked for multi-location operators. Instant PDF download.">

  <!-- Hero -->
  <section class="hero" style="padding:5rem 0 4rem;">
    <div class="container" style="max-width:720px;text-align:center;">
      <span class="section-label" style="color:var(--teal-light);">Free Download</span>
      <h1 style="font-size:clamp(2rem,4.5vw,2.8rem);color:white;">The Complete Operator's Software Toolkit</h1>
      <p style="font-size:1.15rem;color:rgba(255,255,255,0.8);max-width:560px;margin:0 auto 2rem;">
        12 tools reviewed, stack-ranked, and priced for operators running multiple locations.
        Instant PDF download. No fluff, no filler — just the tools that work.
      </p>

      <form
        class="email-form"
        action="https://app.kit.com/forms/9204092/subscriptions"
        method="post"
        style="max-width:480px;margin:0 auto;"
      >
        <input type="hidden" name="redirect_to" value="https://operatorstack.tech/thank-you" />
        <input type="email" name="email_address" placeholder="you@company.com" required />
        <button type="submit">Get the Free Toolkit</button>
      </form>
      <p style="font-size:0.8rem;color:var(--gray-400);margin-top:0.75rem;">
        No spam. Unsubscribe anytime. Delivered instantly to your inbox.
      </p>
    </div>
  </section>

  <!-- What's Inside -->
  <section class="section">
    <div class="container" style="max-width:720px;">
      <span class="section-label">What's Inside</span>
      <h2 style="font-family:var(--font-heading);font-weight:800;font-size:1.6rem;color:var(--navy);margin-bottom:1.5rem;">
        12 Tools Across Every Operator Category
      </h2>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">CRM</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Pipeline, contacts, and multi-location sub-accounts</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Email Marketing</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Newsletters, sequences, and deliverability</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Automation</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Workflow glue between every tool in the stack</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Contracts</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Proposals, e-signatures, and document analytics</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Scheduling</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Employee scheduling and labor cost tracking</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Payroll</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Multi-state compliance and tip tracking</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Hosting</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">WordPress hosting and site performance</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">WiFi &amp; Network</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Access points, cloud management, captive portals</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">POS</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Point of sale for restaurants and retail</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Training</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Course platforms for staff and partner education</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Analytics</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Reporting and performance tracking across locations</p>
        </div>
        <div class="card" style="padding:1.25rem;">
          <h4 style="font-family:var(--font-heading);font-weight:700;color:var(--navy);margin-bottom:0.25rem;">Project Management</h4>
          <p style="font-size:0.9rem;color:var(--gray-600);margin:0;">Deployment tracking and operational dashboards</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section-alt">
    <div class="container" style="max-width:720px;text-align:center;">
      <div class="verdict-box" style="text-align:left;">
        <h3>Built from 50+ Real Venue Deployments</h3>
        <p>
          This isn't a list assembled from product pages and free trials. Every tool
          in the toolkit has been purchased with real money, deployed in real businesses,
          and tested across restaurants, salons, gyms, and service companies. The rankings
          reflect what actually works at scale — not what pays the highest affiliate commission.
        </p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="email-signup">
    <div class="container" style="max-width:560px;">
      <h2>Download the Toolkit — Free</h2>
      <p>Enter your email and the PDF arrives instantly. No spam, unsubscribe anytime.</p>
      <form
        class="email-form"
        action="https://app.kit.com/forms/9204092/subscriptions"
        method="post"
      >
        <input type="hidden" name="redirect_to" value="https://operatorstack.tech/thank-you" />
        <input type="email" name="email_address" placeholder="you@company.com" required />
        <button type="submit">Get the Free Toolkit</button>
      </form>
    </div>
  </section>

  <!-- Disclosure -->
  <section class="section" style="padding:2rem 0;">
    <div class="container" style="max-width:720px;">
      <p style="font-size:0.8rem;color:var(--gray-400);text-align:center;">
        Some tools in the toolkit include affiliate links. If you purchase through them,
        we may earn a commission at no extra cost to you. This never influences our rankings.
        Read our <a href="/affiliate-disclaimer">full affiliate disclaimer</a>.
      </p>
    </div>
  </section>

</Base>
