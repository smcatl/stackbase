---
import { site } from '../config/site';

const initials = site.name
  .replace(/[^A-Za-z]/g, '')
  .slice(0, 2)
  .toUpperCase();
---
<div class="author-bio">
  <div class="author-bio-avatar">
    <div class="author-avatar-circle">{initials}</div>
  </div>
  <div class="author-bio-content">
    <div class="author-bio-header">
      <strong class="author-bio-name">The {site.author}</strong>
      <span class="author-bio-title">{site.tagline}</span>
    </div>
    <p class="author-bio-text">
      <slot>
        Our team has years of hands-on deployment experience across {site.niche || 'this industry'}.
        Every review is based on real-world use — not free trials or press kits.
      </slot>
    </p>
    <a href="/about" class="author-bio-link">About {site.name} →</a>
  </div>
</div>
