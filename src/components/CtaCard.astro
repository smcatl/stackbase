---
import AffiliateLink from './AffiliateLink.astro';
import StarRating from './StarRating.astro';

interface Props {
  slug: string;            // affiliate slug
  title: string;
  rating?: number;
  bestFor?: string;
  price?: string;
  ctaLabel?: string;
}
const { slug, title, rating, bestFor, price, ctaLabel = 'Try It' } = Astro.props;
---
<aside class="cta-card">
  <div class="cta-card-body">
    <h4>{title}</h4>
    {rating !== undefined && <StarRating rating={rating} size="sm" />}
    {bestFor && <p class="cta-bestfor"><strong>Best for:</strong> {bestFor}</p>}
    {price && <p class="cta-price">{price}</p>}
    <slot />
  </div>
  <AffiliateLink slug={slug} label={ctaLabel} cta={true} />
</aside>

<style>
  .cta-card {
    border: 1px solid var(--gray-200, #E5E7EB);
    border-left: 4px solid var(--brand, var(--teal));
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin: 1.75rem 0;
    background: #FAFAFA;
  }
  .cta-card h4 { margin: 0 0 .5rem; }
  .cta-bestfor, .cta-price { margin: .35rem 0; font-size: .9rem; color: var(--gray-600, #4B5563); }
  .cta-card .affiliate-cta {
    display: inline-block;
    margin-top: .85rem;
    padding: .65rem 1.25rem;
    background: var(--brand, var(--teal));
    color: white;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
  }
</style>
