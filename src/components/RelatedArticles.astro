---
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  /** Current article slug — excluded from results. */
  currentSlug: string;
  /** Tags to match against. Sorted by overlap count. */
  tags?: string[];
  /** Collection to draw from. Defaults to 'reviews'. */
  collection?: 'reviews' | 'guides' | 'comparisons' | 'blog';
  limit?: number;
}

const { currentSlug, tags = [], collection = 'reviews', limit = 3 } = Astro.props;

const entries = await getCollection(collection, ({ data, slug }) => {
  return !data.draft && slug !== currentSlug;
});

// Score by tag overlap, fall back to recency.
const scored = entries
  .map((e) => {
    const overlap = e.data.tags.filter((t: string) => tags.includes(t)).length;
    return { entry: e, score: overlap };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return new Date(b.entry.data.publishDate).getTime() - new Date(a.entry.data.publishDate).getTime();
  })
  .slice(0, limit)
  .map((s) => s.entry);
---
{scored.length > 0 && (
  <section class="related">
    <h3>Related reading</h3>
    <ul>
      {scored.map((e: CollectionEntry<typeof collection>) => (
        <li>
          <a href={`/${collection}/${e.slug}`}>
            <strong>{e.data.title}</strong>
            <span>{e.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--gray-200, #E5E7EB); }
  .related h3 { margin-bottom: 1rem; }
  .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: .85rem; }
  .related a {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--gray-50, #F9FAFB);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    transition: border-color .15s;
  }
  .related a:hover { border-color: var(--brand, var(--teal)); }
  .related strong { display: block; color: var(--navy, #0A0F2C); margin-bottom: .25rem; }
  .related span { color: var(--gray-600, #4B5563); font-size: .9rem; }
</style>
