---
/**
 * NewsletterSignup — generic email capture box.
 *
 * Posts to /api/subscribe, which dispatches to whatever provider is configured
 * via NEWSLETTER_PROVIDER env var (convertkit | aweber | resend).
 *
 * Per-site configuration lives in env vars; this component is purely visual.
 */
interface Props {
  title?: string;
  description?: string;
  ctaLabel?: string;
  bullets?: string[];
  variant?: 'inline' | 'hero';
}

const {
  title = 'Get the Insider Newsletter',
  description = 'One email a week. Real reviews, no fluff. Unsubscribe anytime.',
  ctaLabel = 'Subscribe',
  bullets = [],
  variant = 'inline',
} = Astro.props;
---
<aside class={`newsletter newsletter-${variant}`}>
  <div class="newsletter-body">
    <h3>{title}</h3>
    <p>{description}</p>
    {bullets.length > 0 && (
      <ul class="newsletter-bullets">
        {bullets.map((b) => <li><span>✓</span> {b}</li>)}
      </ul>
    )}
    <form class="newsletter-form" data-newsletter>
      <input
        type="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />
      <button type="submit">{ctaLabel}</button>
    </form>
    <p class="newsletter-fineprint" data-newsletter-status></p>
  </div>
</aside>

<script>
  document.querySelectorAll('form[data-newsletter]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const status = f.parentElement?.querySelector('[data-newsletter-status]') as HTMLElement;
      const email = (f.querySelector('input[name="email"]') as HTMLInputElement).value;
      const btn = f.querySelector('button') as HTMLButtonElement;

      btn.disabled = true;
      status.textContent = 'Subscribing…';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        status.textContent = '✓ Check your email to confirm.';
        f.reset();
        if (typeof (window as any).plausible === 'function') {
          (window as any).plausible('Newsletter Signup');
        }
      } catch (err) {
        status.textContent = '✗ ' + (err as Error).message;
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .newsletter {
    border-radius: 14px;
    padding: clamp(1.25rem, 3.5vw, 2rem);
    margin: 2rem 0;
    background: linear-gradient(135deg, var(--navy, #0D1F3C) 0%, #1565C0 100%);
    color: white;
  }
  .newsletter-hero {
    padding: clamp(2rem, 5vw, 3rem) clamp(1.25rem, 4vw, 2rem);
    text-align: center;
  }
  .newsletter h3 { color: white; margin: 0 0 .5rem; font-size: clamp(1.2rem, 2.5vw, 1.5rem); }
  .newsletter p { color: rgba(255,255,255,0.75); margin: 0 0 1rem; font-size: clamp(0.95rem, 1.4vw, 1rem); }
  .newsletter-bullets {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    display: grid;
    gap: .35rem;
  }
  .newsletter-bullets li { color: rgba(255,255,255,0.9); font-size: .95rem; }
  .newsletter-bullets span { color: var(--brand-light, var(--teal-light, #4DB6AC)); font-weight: 700; margin-right: .35rem; }
  .newsletter-form {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: 1.25rem;
  }
  @media (max-width: 480px) {
    .newsletter-form { flex-direction: column; }
    .newsletter-form input, .newsletter-form button { width: 100%; }
  }
  .newsletter-hero .newsletter-form { max-width: 440px; margin-left: auto; margin-right: auto; }
  .newsletter-form input {
    flex: 1;
    padding: .75rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.1);
    color: white;
    font-size: 1rem;
  }
  .newsletter-form input::placeholder { color: rgba(255,255,255,0.5); }
  .newsletter-form input:focus { outline: 2px solid var(--brand-light, var(--teal-light)); border-color: transparent; }
  .newsletter-form button {
    padding: .75rem 1.5rem;
    border-radius: 8px;
    border: none;
    background: var(--brand-light, var(--teal-light, #4DB6AC));
    color: var(--navy, #0D1F3C);
    font-weight: 700;
    cursor: pointer;
    transition: opacity .15s;
  }
  .newsletter-form button:hover { opacity: 0.9; }
  .newsletter-form button:disabled { opacity: 0.5; cursor: not-allowed; }
  .newsletter-fineprint {
    margin-top: .75rem;
    font-size: .8rem;
    color: rgba(255,255,255,0.6);
    min-height: 1.2em;
  }
</style>
