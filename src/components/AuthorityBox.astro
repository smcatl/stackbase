---
/**
 * AuthorityBox — per-article E-E-A-T signal.
 *
 * Drop near the top of any review/guide. Communicates: who reviewed it,
 * their credentials, when it was last fact-checked. Big lift for Google's
 * Helpful Content classifier.
 *
 * Usage in MDX:
 *   <AuthorityBox
 *     reviewer="Stosh Cohen"
 *     role="Multi-Location Operator"
 *     credentials={["50+ venues deployed", "10 years operations"]}
 *     lastReviewed="2026-04-07"
 *     methodologyHref="/methodology"
 *   />
 */
interface Props {
  reviewer: string;
  role?: string;
  credentials?: string[];
  lastReviewed?: string;
  methodologyHref?: string;
}
const {
  reviewer,
  role,
  credentials = [],
  lastReviewed,
  methodologyHref = '/about',
} = Astro.props;

const formattedDate = lastReviewed
  ? new Date(lastReviewed).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const initials = reviewer
  .split(/\s+/)
  .map((p) => p[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---
<aside class="authority-box">
  <div class="authority-avatar">{initials}</div>
  <div class="authority-body">
    <div class="authority-header">
      <strong>Reviewed by {reviewer}</strong>
      {role && <span class="authority-role">{role}</span>}
    </div>
    {credentials.length > 0 && (
      <ul class="authority-credentials">
        {credentials.map((c) => <li>✓ {c}</li>)}
      </ul>
    )}
    {formattedDate && (
      <p class="authority-date">
        Last fact-checked {formattedDate} · <a href={methodologyHref}>How we review</a>
      </p>
    )}
  </div>
</aside>

<style>
  .authority-box {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--gray-50, #F9FAFB);
    border: 1px solid var(--gray-200, #E5E7EB);
    border-left: 4px solid var(--brand, var(--teal));
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
  .authority-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--brand, var(--teal));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .authority-body { flex: 1; min-width: 0; }
  .authority-header { display: flex; flex-wrap: wrap; align-items: baseline; gap: .5rem; }
  .authority-header strong { color: var(--navy, #0D1F3C); font-size: 1rem; }
  .authority-role { color: var(--gray-600, #4B5563); font-size: .85rem; }
  .authority-credentials {
    margin: .5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: .5rem 1rem;
  }
  .authority-credentials li {
    font-size: .85rem;
    color: var(--gray-700, #334155);
  }
  .authority-date {
    margin: .65rem 0 0;
    font-size: .8rem;
    color: var(--gray-600, #4B5563);
  }
  .authority-date a { color: var(--brand, var(--teal)); }
</style>
