---
import { getAffiliate } from '../data/affiliates';

interface Props {
  /** Slug from src/data/affiliates.ts */
  slug: string;
  /** Optional override for the visible link text. Defaults to the affiliate name. */
  label?: string;
  /** Render as a button (CTA) instead of inline link. */
  cta?: boolean;
  class?: string;
}

const { slug, label, cta = false, class: className = '' } = Astro.props;
const affiliate = getAffiliate(slug);

if (!affiliate) {
  throw new Error(`AffiliateLink: unknown slug "${slug}". Add it to src/data/affiliates.ts`);
}

// All affiliate links go through /recommends/<slug> for cloaking + future link rotation.
const href = `/recommends/${affiliate.slug}`;
const text = label ?? affiliate.name;
const classes = cta ? `affiliate-cta ${className}` : `affiliate-link ${className}`;
---
<a
  href={href}
  class={classes}
  rel="sponsored nofollow noopener"
  target="_blank"
  data-affiliate={affiliate.slug}
>
  {cta ? <>{text} →</> : text}<slot />
</a>
