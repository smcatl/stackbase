{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 200
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string"
    },
    "readTime": {
      "default": "8 min read",
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affiliateSlugs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affiliateDisclosure": {
      "default": true,
      "type": "boolean"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "image": {
      "type": "string"
    },
    "products": {
      "minItems": 2,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "winner": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "publishDate",
    "category",
    "products"
  ]
}