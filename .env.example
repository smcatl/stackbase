# =====================================================================
# Stackbase — per-vertical configuration
# Copy to .env (local) and add the same vars to Vercel project settings.
# Anything prefixed PUBLIC_ is exposed to the browser; everything else is
# server-only and only readable inside api/.
# =====================================================================

# --- Identity ---------------------------------------------------------
PUBLIC_SITE_NAME=OperatorStack
PUBLIC_BRAND_WORD_1=Operator
PUBLIC_BRAND_WORD_2=Stack
PUBLIC_SITE_URL=https://operatorstack.tech
PUBLIC_SITE_DESCRIPTION=Software reviews and tech stack advice for multi-location business operators. Written by an operator, for operators.
PUBLIC_BRAND_TAGLINE=Software reviews and tech stack advice written by a multi-location operator with thousands of venues deployed. No fluff, no hype — just what actually works.
PUBLIC_SITE_AUTHOR=OperatorStack Team
PUBLIC_SITE_NICHE=multi-location business operators
PUBLIC_SITE_ENTITY=operators

# --- Brand colors -----------------------------------------------------
# IMPORTANT: hex values MUST be quoted, otherwise Vite's dotenv parser
# treats `#` as a comment marker and strips the color, leaving empty.
PUBLIC_BRAND_ACCENT="#00897B"
PUBLIC_BRAND_ACCENT_LIGHT="#4DB6AC"
PUBLIC_BRAND_BG="#0D1F3C"
PUBLIC_BRAND_TEXT="#FFFFFF"

# --- Brand typography -------------------------------------------------
# Quote values that contain a space. Google Fonts URL must include every
# weight used in global.css (400/500/600/700/800 typical).
PUBLIC_FONT_DISPLAY='Syne', sans-serif
PUBLIC_FONT_BODY='DM Sans', sans-serif
PUBLIC_FONT_GOOGLE_URL=https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap

# --- Brand mode -------------------------------------------------------
# 'dark' for every site except RealEstateOpsHub which uses 'light' (the
# only light-background site in the portfolio). When set to 'light',
# Base.astro loads light-mode.css to invert backgrounds, text, and
# surface colors while keeping the typography system intact.
PUBLIC_BRAND_MODE=dark

# Optional: path to a per-site SVG logo asset if needed for anything
# beyond favicon. Defaults to /favicon.svg.
PUBLIC_LOGO_SVG_PATH=/favicon.svg

# --- Analytics + verification ----------------------------------------
PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/pa-XXXXXXX.js
PUBLIC_PLAUSIBLE_DOMAIN=operatorstack.tech
PUBLIC_IMPACT_CDN_ID=
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_IMPACT_SITE_VERIFICATION=

# --- Footer link columns (JSON arrays) -------------------------------
PUBLIC_FOOTER_REVIEWS=[{"label":"GoHighLevel","href":"/reviews/gohighlevel"},{"label":"ConvertKit","href":"/reviews/convertkit"},{"label":"Kinsta","href":"/reviews/kinsta"},{"label":"All Reviews →","href":"/reviews"}]
PUBLIC_FOOTER_GUIDES=[{"label":"My Tech Stack","href":"/guides/operator-tech-stack"},{"label":"All Guides →","href":"/guides"}]

# --- Server-only (api/ functions) ------------------------------------
ANTHROPIC_API_KEY=
OSGIT_TOKEN=
GOOGLE_SERVICE_ACCOUNT_KEY=
EDITORIAL_PERSONA=You are a member of the OperatorStack editorial team. Your team has collectively managed thousands of business locations across restaurants, gyms, salons, retail, and service businesses, and evaluated thousands of software tools over your careers. Write from a team perspective using 'we' and 'our team'. Voice is direct, experienced, and credible. Never use filler phrases.
EDITORIAL_NICHE=multi-location business operators
